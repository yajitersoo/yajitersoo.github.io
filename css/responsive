@media (max-width: 900px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }

  .hero-title {
    font-size: 2.4rem;
  }

  .nav-menu {
    gap: 16px;
  }
}

@media (max-width: 640px) {
  .nav-wrap {
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }

  .nav-menu {
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-section {
    padding: 56px 0;
  }

  .hero-title {
    font-size: 2rem;
  }

  .hero-description {
    font-size: 1rem;
  }

  .btn {
    width: 100%;
    text-align: center;
  }

  .hero-actions {
    flex-direction: column;
  }
}


@media (max-width: 900px) {
  .capabilities-grid {
    grid-template-columns: 1fr;
  }

  .section-title {
    font-size: 1.9rem;
  }
}

@media (max-width: 640px) {
  .capabilities-section {
    padding: 56px 0;
  }

  .section-title {
    font-size: 1.7rem;
  }

  .capability-card {
    padding: 22px;
  }
}

@media (max-width: 900px) {
  .profile-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
}

@media (max-width: 640px) {
  .profile-section {
    padding: 56px 0;
  }
}
